{
  "name": "cleyes",
  "version": "1.0.0",
  "description": "cleyes — webcam-driven RGB dissolve visual effect",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/jsdom": "^28.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "lil-gui": "^0.19.2"
  }
}
